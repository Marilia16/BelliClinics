<div class="mx-auto w-full max-w-md py-10">
  <div class="rounded-2xl border border-gray-200 bg-white p-6 shadow-theme-xs dark:border-gray-800 dark:bg-gray-900">
    <h1 class="mb-2 font-semibold text-gray-800 text-title-sm dark:text-white/90 sm:text-title-md">Redefinir senha</h1>
    <p class="mb-6 text-sm text-gray-500 dark:text-gray-400">Cadastre sua nova senha de acesso.</p>

    <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :put }) do |f| %>
      <%= render "devise/shared/error_messages", resource: resource %>
      <%= f.hidden_field :reset_password_token %>

      <div class="space-y-5">
        <div>
          <%= f.label :password, "Nova senha", class: "mb-1.5 block text-sm font-medium text-gray-700 dark:text-gray-400" %>
          <% if @minimum_password_length %>
            <p class="mb-1 text-xs text-gray-500 dark:text-gray-400"><%= @minimum_password_length %> caracteres no mínimo</p>
          <% end %>
          <%= f.password_field :password, autofocus: true, autocomplete: "new-password", class: "h-11 w-full rounded-lg border border-gray-300 bg-transparent py-2.5 px-4 text-sm text-gray-800 shadow-theme-xs placeholder:text-gray-400 focus:border-brand-300 focus:outline-hidden focus:ring-3 focus:ring-brand-500/10 dark:border-gray-700 dark:bg-gray-900 dark:text-white/90 dark:placeholder:text-white/30 dark:focus:border-brand-800" %>
        </div>

        <div>
          <%= f.label :password_confirmation, "Confirmar nova senha", class: "mb-1.5 block text-sm font-medium text-gray-700 dark:text-gray-400" %>
          <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "h-11 w-full rounded-lg border border-gray-300 bg-transparent py-2.5 px-4 text-sm text-gray-800 shadow-theme-xs placeholder:text-gray-400 focus:border-brand-300 focus:outline-hidden focus:ring-3 focus:ring-brand-500/10 dark:border-gray-700 dark:bg-gray-900 dark:text-white/90 dark:placeholder:text-white/30 dark:focus:border-brand-800" %>
        </div>

        <%= f.submit "Salvar nova senha", class: "flex items-center justify-center w-full px-4 py-3 text-sm font-medium text-white transition rounded-lg bg-brand-500 shadow-theme-xs hover:bg-brand-600" %>
      </div>
    <% end %>

    <%= render "devise/shared/links" %>

    <div class="mt-8">
      <%= link_to root_path, class: "inline-flex items-center text-sm text-gray-500 transition-colors hover:text-gray-700 dark:text-gray-400 dark:hover:text-gray-300" do %>
        Voltar para home
      <% end %>
    </div>
  </div>
</div>
