<div class="mt-5 space-y-2 text-sm">
  <%- if controller_name != "sessions" %>
    <p><%= link_to "Entrar", new_session_path(resource_name), class: "text-brand-500 hover:text-brand-600 dark:text-brand-400" %></p>
  <% end %>

  <%- if devise_mapping.registerable? && controller_name != "registrations" %>
    <p><%= link_to "Criar conta", new_registration_path(resource_name), class: "text-brand-500 hover:text-brand-600 dark:text-brand-400" %></p>
  <% end %>

  <%- if devise_mapping.recoverable? && controller_name != "passwords" && controller_name != "registrations" %>
    <p><%= link_to "Esqueceu sua senha?", new_password_path(resource_name), class: "text-brand-500 hover:text-brand-600 dark:text-brand-400" %></p>
  <% end %>

  <%- if devise_mapping.confirmable? && controller_name != "confirmations" %>
    <p><%= link_to "Não recebeu as instruções de confirmação?", new_confirmation_path(resource_name), class: "text-brand-500 hover:text-brand-600 dark:text-brand-400" %></p>
  <% end %>

  <%- if devise_mapping.lockable? && resource_class.unlock_strategy_enabled?(:email) && controller_name != "unlocks" %>
    <p><%= link_to "Não recebeu as instruções de desbloqueio?", new_unlock_path(resource_name), class: "text-brand-500 hover:text-brand-600 dark:text-brand-400" %></p>
  <% end %>

  <%- if devise_mapping.omniauthable? %>
    <%- resource_class.omniauth_providers.each do |provider| %>
      <%= button_to "Entrar com #{OmniAuth::Utils.camelize(provider)}",
                    omniauth_authorize_path(resource_name, provider),
                    data: { turbo: false },
                    class: "inline-flex items-center justify-center rounded-lg bg-brand-500 px-4 py-2 text-sm font-medium text-white transition hover:bg-brand-600" %>
    <% end %>
  <% end %>
</div>
