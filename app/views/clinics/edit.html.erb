<% content_for :title, "Editar clínica" %>

<div class="mx-auto w-full max-w-3xl space-y-4">
  <%= render "shared/dashboard/breadcrumb",
             items: [
               { label: "Dashboard", path: clinics_path },
               { label: "Clínicas", path: clinics_path },
               { label: "Editar clínica", current: true }
             ] %>

  <div class="rounded-2xl border border-gray-200 bg-white p-5 dark:border-gray-800 dark:bg-white/[0.03] sm:p-6">
    <div class="mb-6 flex items-start gap-3">
      <span class="inline-flex h-11 w-11 items-center justify-center rounded-xl bg-brand-50 text-brand-500 dark:bg-brand-500/10 dark:text-brand-400">
        <svg class="h-5 w-5" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M3.75 16.25V6.25L10 3.75L16.25 6.25V16.25H3.75Z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round" />
          <path d="M10 7.5V12.5M7.5 10H12.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" opacity="0.35" />
          <path d="M8 13.2L9.5 14.7L12.8 11.4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
      </span>
      <div>
        <h1 class="text-2xl font-semibold text-gray-800 dark:text-white/90">Editar clínica</h1>
        <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">Atualize os dados da clínica selecionada.</p>
      </div>
    </div>
    <%= render "form", clinic: @clinic %>
  </div>

  <div>
    <%= link_to "Ver detalhes da clínica", @clinic, class: "inline-flex items-center rounded-lg border border-gray-300 px-4 py-2.5 text-sm font-medium text-gray-700 transition hover:bg-gray-100 dark:border-gray-700 dark:text-gray-300 dark:hover:bg-gray-800" %>
  </div>
</div>
