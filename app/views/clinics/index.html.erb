<% content_for :title, "Clínicas" %>

<div class="space-y-6">
  <div class="space-y-3">
    <%= render "shared/dashboard/breadcrumb",
               items: [
                 { label: "Dashboard", path: clinics_path },
                 { label: "Clínicas", current: true }
               ] %>
  </div>

  <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
    <div class="flex items-start gap-3">
      <span class="inline-flex h-11 w-11 items-center justify-center rounded-xl bg-brand-50 text-brand-500 dark:bg-brand-500/10 dark:text-brand-400">
        <svg class="h-5 w-5" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M3.75 16.25V6.25L10 3.75L16.25 6.25V16.25H3.75Z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round" />
          <path d="M7.5 10H12.5M10 7.5V12.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
        </svg>
      </span>
      <div>
        <h1 class="text-2xl font-semibold text-gray-800 dark:text-white/90">Clínicas</h1>
        <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">Gerencie as clínicas cadastradas no sistema.</p>
      </div>
    </div>
    <%= link_to "Nova clínica", new_clinic_path, class: "inline-flex items-center justify-center rounded-lg bg-brand-500 px-4 py-2.5 text-sm font-medium text-white shadow-theme-xs transition hover:bg-brand-600" %>
  </div>

  <div class="overflow-hidden rounded-2xl border border-gray-200 bg-white dark:border-gray-800 dark:bg-white/[0.03]">
    <div class="border-b border-gray-100 px-5 py-4 dark:border-gray-800 sm:px-6">
      <h2 class="text-base font-semibold text-gray-800 dark:text-white/90">Lista de clínicas</h2>
    </div>

    <% if @clinics.any? %>
      <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-gray-200 dark:divide-gray-800">
          <thead class="bg-gray-50 dark:bg-gray-900/40">
            <tr>
              <th class="px-5 py-3 text-left text-xs font-medium uppercase tracking-wider text-gray-500 dark:text-gray-400">Nome</th>
              <th class="px-5 py-3 text-left text-xs font-medium uppercase tracking-wider text-gray-500 dark:text-gray-400">CNPJ</th>
              <th class="px-5 py-3 text-left text-xs font-medium uppercase tracking-wider text-gray-500 dark:text-gray-400">Usuário Proprietário</th>
              <th class="px-5 py-3 text-right text-xs font-medium uppercase tracking-wider text-gray-500 dark:text-gray-400">Ações</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100 dark:divide-gray-800">
            <% @clinics.each do |clinic| %>
              <%= render "clinic", clinic: clinic %>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <div class="px-5 py-10 text-center sm:px-6">
        <p class="text-sm text-gray-500 dark:text-gray-400">Nenhuma clínica encontrada.</p>
      </div>
    <% end %>
  </div>
</div>
