<section class="flex h-full w-full flex-col items-center justify-center px-6 text-center">
  <span class="mb-5 inline-flex items-center rounded-full bg-violet-100 px-4 py-1 text-sm font-medium text-violet-700">
    BelliClinics
  </span>

  <h1 class="text-4xl font-bold tracking-tight text-slate-900 sm:text-5xl">
    Gestão moderna para clínicas de beleza e estética
  </h1>

  <p class="mt-6 max-w-2xl text-base leading-7 text-slate-600 sm:text-lg">
    Organize atendimentos, cadastros e rotinas da sua clínica em uma interface clara,
    rápida e preparada para crescimento.
  </p>

  <div class="mt-10 flex flex-col gap-3 sm:flex-row">
    <%= link_to "Comecar agora", clinics_path, class: "inline-flex items-center justify-center rounded-lg bg-violet-600 px-5 py-3 text-sm font-semibold text-white shadow-sm transition hover:bg-violet-500 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-violet-600" %>

    <%= link_to "Ver funcionalidades", pages_path(:id => "features"), class: "inline-flex items-center justify-center rounded-lg border border-slate-300 bg-white px-5 py-3 text-sm font-semibold text-slate-700 transition hover:bg-slate-100" %>
  </div>
</section>