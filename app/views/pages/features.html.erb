<section class="flex h-full w-full flex-col px-6 py-12 sm:px-10 sm:py-16">
  <div class="mx-auto w-full max-w-7xl">
    <div class="mb-8">
      <%= link_to "Voltar para home", root_path, class: "inline-flex items-center justify-center rounded-lg border border-slate-300 bg-white px-4 py-2 text-sm font-semibold text-slate-700 transition hover:bg-slate-100" %>
    </div>

    <div class="text-center">
      <span class="mb-5 inline-flex items-center rounded-full bg-violet-100 px-4 py-1 text-sm font-medium text-violet-700">
        Funcionalidades
      </span>

      <h1 class="text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl">
        Recursos para gerenciar sua clinica de estetica
      </h1>

      <p class="mx-auto mt-4 max-w-3xl text-base leading-7 text-slate-600 sm:text-lg">
        Controle agenda, equipe, clientes e financeiro em um unico lugar, com foco
        na rotina de clinicas de beleza e estetica.
      </p>
    </div>

    <div class="mt-10 grid grid-cols-1 gap-5 md:grid-cols-2 xl:grid-cols-3">
      <article class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
        <h2 class="text-lg font-semibold text-slate-900">Agenda inteligente</h2>
        <p class="mt-2 text-sm leading-6 text-slate-600">
          Organize horarios por profissional, sala e tipo de procedimento com
          confirmacoes automaticas.
        </p>
      </article>

      <article class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
        <h2 class="text-lg font-semibold text-slate-900">Cadastro completo de clientes</h2>
        <p class="mt-2 text-sm leading-6 text-slate-600">
          Centralize dados pessoais, historico de atendimentos, observacoes
          clinicas e anexos importantes.
        </p>
      </article>

      <article class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
        <h2 class="text-lg font-semibold text-slate-900">Prontuario estetico</h2>
        <p class="mt-2 text-sm leading-6 text-slate-600">
          Registre evolucao de tratamentos com fotos, protocolos aplicados e
          recomendacoes de acompanhamento.
        </p>
      </article>

      <article class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
        <h2 class="text-lg font-semibold text-slate-900">Controle financeiro</h2>
        <p class="mt-2 text-sm leading-6 text-slate-600">
          Acompanhe faturamento, comissoes, fluxo de caixa e despesas operacionais
          em paineis simples.
        </p>
      </article>

      <article class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
        <h2 class="text-lg font-semibold text-slate-900">Pacotes e assinaturas</h2>
        <p class="mt-2 text-sm leading-6 text-slate-600">
          Venda planos recorrentes e combos de procedimentos com controle de saldo
          e validade por cliente.
        </p>
      </article>

      <article class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
        <h2 class="text-lg font-semibold text-slate-900">Relatorios de desempenho</h2>
        <p class="mt-2 text-sm leading-6 text-slate-600">
          Visualize indicadores de ocupacao, retorno de clientes e servicos mais
          vendidos para decidir com dados.
        </p>
      </article>
    </div>
  </div>
</section>
