<aside
  data-controller="sidebar"
  data-sidebar-storage-key-value="selectedSidebarMenu"
  class="sidebar fixed left-0 top-0 z-9999 flex h-screen w-[290px] -translate-x-full flex-col overflow-y-hidden border-r border-gray-200 bg-white px-5 transition-transform duration-300 ease-linear dark:border-gray-800 dark:bg-black lg:static lg:translate-x-0">
  <!-- SIDEBAR HEADER -->
  <div
    class="flex items-center gap-2 pt-8 sidebar-header pb-7">
    <%= link_to root_path do %>
      <span class="logo">
        <%= image_tag "logo/logo.svg", class: "dark:hidden", alt: "Logo" %>
        <%= image_tag "logo/logo-dark.svg", class: "hidden dark:block", alt: "Logo" %>
      </span>
    <% end %>
  </div>
  <!-- SIDEBAR HEADER -->

  <div class="flex flex-col overflow-y-auto duration-300 ease-linear no-scrollbar">
    <!-- Sidebar Menu -->
    <nav>
      <!-- Menu Group -->
      <div>
        <h3 class="mb-4 text-xs uppercase leading-[20px] text-gray-400">
          <span
            class="menu-group-title">
            MENU
          </span>
        </h3>

        <ul class="flex flex-col gap-4 mb-6">

          <!-- Menu Item Minhas clínicas -->
          <li>
            <%= link_to clinics_path, class: "menu-item group" do %>
              <svg
                width="24"
                height="24"
                viewBox="0 0 24 24"
                fill="none"
                xmlns="http://www.w3.org/2000/svg">
                <path
                  fill-rule="evenodd"
                  clip-rule="evenodd"
                  d="M8 2C8.41421 2 8.75 2.33579 8.75 2.75V3.75H15.25V2.75C15.25 2.33579 15.5858 2 16 2C16.4142 2 16.75 2.33579 16.75 2.75V3.75H18.5C19.7426 3.75 20.75 4.75736 20.75 6V9V19C20.75 20.2426 19.7426 21.25 18.5 21.25H5.5C4.25736 21.25 3.25 20.2426 3.25 19V9V6C3.25 4.75736 4.25736 3.75 5.5 3.75H7.25V2.75C7.25 2.33579 7.58579 2 8 2ZM8 5.25H5.5C5.08579 5.25 4.75 5.58579 4.75 6V8.25H19.25V6C19.25 5.58579 18.9142 5.25 18.5 5.25H16H8ZM19.25 9.75H4.75V19C4.75 19.4142 5.08579 19.75 5.5 19.75H18.5C18.9142 19.75 19.25 19.4142 19.25 19V9.75Z"
                  fill=""
                />
              </svg>

              <span
                class="menu-item-text">
                Minhas clínicas
              </span>
            <% end %>
          </li>
          <!-- Menu Item Minhas clínicas -->
          <% if current_user&.has_role?(:admin) %>
             <li>
                <%= link_to manager_users_path, class: "menu-item group" do %>
                  <svg
                    width="24"
                    height="24"
                    viewBox="0 0 24 24"
                    fill="none"
                    xmlns="http://www.w3.org/2000/svg">
                    <path
                      fill-rule="evenodd"
                      clip-rule="evenodd"
                      d="M8 2C8.41421 2 8.75 2.33579 8.75 2.75V3.75H15.25V2.75C15.25 2.33579 15.5858 2 16 2C16.4142 2 16.75 2.33579 16.75 2.75V3.75H18.5C19.7426 3.75 20.75 4.75736 20.75 6V9V19C20.75 20.2426 19.7426 21.25 18.5 21.25H5.5C4.25736 21.25 3.25 20.2426 3.25 19V9V6C3.25 4.75736 4.25736 3.75 5.5 3.75H7.25V2.75C7.25 2.33579 7.58579 2 8 2ZM8 5.25H5.5C5.08579 5.25 4.75 5.58579 4.75 6V8.25H19.25V6C19.25 5.58579 18.9142 5.25 18.5 5.25H16H8ZM19.25 9.75H4.75V19C4.75 19.4142 5.08579 19.75 5.5 19.75H18.5C18.9142 19.75 19.25 19.4142 19.25 19V9.75Z"
                      fill=""
                    />
                  </svg>

                  <span
                    class="menu-item-text">
                    Gerenciar funções de usuários
                <% end %>
              </li>
            <% end %>
            </ul>
      </div>

    </nav>
    <!-- Sidebar Menu -->

  </div>
</aside>
